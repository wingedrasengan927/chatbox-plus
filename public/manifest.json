{
  "manifest_version": 3,
  "name": "Chatbox Plus Editor",
  "version": "1.3",
  "description": "A modern chatbox to interact with LLMs.",
  "action": {
    "default_title": "Chatbox Plus"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["sidePanel", "tabs", "scripting", "clipboardRead"],
  "host_permissions": [
    "*://aistudio.google.com/*",
    "*://gemini.google.com/*",
    "*://chatgpt.com/*",
    "*://chat.openai.com/*",
    "*://claude.ai/*"
  ]
}
